#!/usr/bin/make -f

export PYBUILD_NAME=geek42
export PYBUILD_SYSTEM=pyproject

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_test:
	PYBUILD_TEST_ARGS="tests/" dh_auto_test

override_dh_auto_install:
	dh_auto_install
	install -d debian/geek42/usr/share/doc/geek42
	install -m 0644 README.md debian/geek42/usr/share/doc/geek42/
	install -m 0644 CHANGELOG.md debian/geek42/usr/share/doc/geek42/
	install -m 0644 SECURITY.md debian/geek42/usr/share/doc/geek42/
	install -d debian/geek42/usr/share/doc/geek42/examples
	install -m 0644 docs/*.md debian/geek42/usr/share/doc/geek42/examples/
