<!DOCTYPE html>
<html lang="{{ config.language | default('en') }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content="geek42">
    <meta name="description" content="{% block meta_description %}{{ config.description }}{% endblock %}">
    <meta name="author" content="{% block meta_author %}{{ config.author }}{% endblock %}">

    {# Open Graph #}
    <meta property="og:site_name" content="{{ config.title }}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}{{ config.title }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ config.description }}{% endblock %}">
    {% block og_extra %}{% endblock %}

    <title>{% block title %}{{ config.title }}{% endblock %}</title>

    <link rel="stylesheet" href="{{ root }}/style.css">
    <link rel="alternate" type="application/rss+xml" title="{{ config.title }} (RSS)" href="{{ root }}/rss.xml">
    <link rel="alternate" type="application/atom+xml" title="{{ config.title }} (Atom)" href="{{ root }}/atom.xml">
</head>
<body>
    <header role="banner">
        <h1><a href="{{ root }}/">{{ config.title }}</a></h1>
        <p class="description">{{ config.description }}</p>
        <nav aria-label="Site navigation">
            <a href="{{ root }}/rss.xml">RSS</a>
            <a href="{{ root }}/atom.xml">Atom</a>
        </nav>
    </header>
    <main role="main">
        {% block content %}{% endblock %}
    </main>
    <footer role="contentinfo">
        <p>Generated by geek42 &mdash; GLEP 42 news to static blog</p>
    </footer>
</body>
</html>
